# Maintainer: Tim M. Madsen <tim@datamadsen.dk>
pkgname=devspanner
pkgver=0.1.0
pkgrel=1
pkgdesc="A small, config-driven terminal UI for the local dev loop"
arch=('x86_64' 'aarch64')
url="https://github.com/datamadsen/devspanner"
license=('MIT')
makedepends=('go')
source=("$pkgname-$pkgver.tar.gz::$url/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP') # run `updpkgsums` after the tag is pushed to pin the checksum

build() {
  cd "$pkgname-$pkgver"
  export CGO_CPPFLAGS="${CPPFLAGS}"
  export CGO_CFLAGS="${CFLAGS}"
  export CGO_CXXFLAGS="${CXXFLAGS}"
  export CGO_LDFLAGS="${LDFLAGS}"
  export GOFLAGS="-buildmode=pie -trimpath -mod=readonly -modcacherw"
  go build -ldflags "-s -w -X main.version=$pkgver" -o devspanner .
}

check() {
  cd "$pkgname-$pkgver"
  go test ./...
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 devspanner "$pkgdir/usr/bin/devspanner"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
  install -Dm644 examples/config.yaml "$pkgdir/usr/share/doc/$pkgname/config.yaml"
}
